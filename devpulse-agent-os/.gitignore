# ==============================================================================
# DevPulse Agent OS — .gitignore
# ==============================================================================

# ── Python / Backend ──────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/
env/
.env/
*.pyc
.pytest_cache/
.coverage
htmlcov/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env
!.env.example

# ── SECRETS — Never commit these ──────────────────────────────────────────────
keys/
*.pem
*.key
*.p12
credentials.json
service-account*.json

# ── Node.js / Frontend ────────────────────────────────────────────────────────
node_modules/
.next/
out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js
.yarn/install-state.gz

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
*.DS_Store
