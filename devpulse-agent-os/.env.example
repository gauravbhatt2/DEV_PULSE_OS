# ==============================================================================
# DevPulse Agent OS — Environment Variables
# Copy this to .env and fill in your real values.
# NEVER commit .env to version control.
# ==============================================================================

# ──────────────────────────────────────────────
# DATABASE (PostgreSQL)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://devpulse:devpulse_secret@localhost:5434/devpulse_db

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────
PROJECT_NAME=DevPulse Agent OS
DEBUG=true

# ──────────────────────────────────────────────
# JIRA INTEGRATION
# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# ──────────────────────────────────────────────
JIRA_EMAIL=your-email@company.com
JIRA_TOKEN=your_jira_api_token
JIRA_DOMAIN=your-workspace.atlassian.net

# ──────────────────────────────────────────────
# GITHUB APP AUTHENTICATION
# Create a GitHub App at: https://github.com/settings/apps
# ──────────────────────────────────────────────
GITHUB_APP_ID=your_github_app_id
GITHUB_INSTALLATION_ID=your_installation_id
GITHUB_PRIVATE_KEY_PATH=keys/devpulse-agent-os.private-key.pem
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# ──────────────────────────────────────────────
# AI PRIORITY ANALYSIS (Optional — Groq LLM)
# Get a free API key at: https://console.groq.com
# Falls back to keyword analysis if not set.
# ──────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ──────────────────────────────────────────────
# LOCAL SLM (Optional — Ollama)
# Run: ollama pull qwen2.5:3b
# ──────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
